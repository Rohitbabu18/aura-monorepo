{
  "name": "aura-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "yarn workspace frontend start",
    "dev:backend": "yarn workspace backend dev",
    "prisma:generate": "yarn workspace backend prisma generate",
    "build": "yarn prisma:generate && yarn workspaces run build"
  }
}