model Address {
  id          String   @id @default(uuid())

  userId      String?  @unique
  hospitalId  String?  @unique

  complete    String?
  city        String?
  state       String?
  country     String?
  pincode     Int?

  user        User?     @relation(fields: [userId], references: [id])
  hospital    Hospital? @relation(fields: [hospitalId], references: [id])

}
